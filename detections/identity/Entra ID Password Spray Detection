// Name: Entra ID Password Spray Detection
// Author: MFA meex
// Date: 2026-02-25
// Description: Detects potential password spray activity by identifying a single IP address generating failed sign-ins across multiple distinct user accounts within a short window.
// Reference: https://attack.mitre.org/techniques/T1110/003/
// Note: To reduce false positives, exclude trusted corporate IP ranges, VPN gateways, or proxy infrastructure.

let Window = 10m;
let UserThreshold = 5;

SigninLogs
// Filters for password failures.
| where TimeGenerated > ago(Window)
| where ResultType == "50126"
// Detects potential password spray behavior from a single IP targeting multiple accounts.
| summarize
    FailedUsers = dcount(UserPrincipalName),
    TotalFailures = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated)
    by IPAddress
| where FailedUsers >= UserThreshold
| project
    IPAddress,
    FailedUsers,
    TotalFailures,
    FirstSeen,
    LastSeen
